{
  "name": "@fund-my-cause/indexer",
  "version": "1.0.0",
  "description": "Indexer service for Fund My Cause - indexes blockchain events and maintains normalized schema",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/migrations/run.ts",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "pg": "^8.11.0",
    "@stellar/stellar-sdk": "14.6.1",
    "dotenv": "^16.0.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "tsx": "^4.6.0",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.0",
    "vitest": "^1.1.0"
  }
}
